# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channels: language × tier (4 channels)
TELEGRAM_CHANNEL_UK_FREE=-100100000001
TELEGRAM_CHANNEL_UK_PRO=-100100000002
TELEGRAM_CHANNEL_EN_FREE=-100100000003
TELEGRAM_CHANNEL_EN_PRO=-100100000004
TELEGRAM_CHANNEL_RU_FREE=-100100000005
TELEGRAM_CHANNEL_RU_PRO=-100100000006

TELEGRAM_ADMIN_IDS=123456789,987654321

# === Database (PostgreSQL 18 on Railway) ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/blaksignals

# === Redis (Railway) ===
REDIS_URL=redis://localhost:6379/0

# === DeepSeek AI ===
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === OpenAI (for embeddings) ===
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Exchange APIs (public, no keys needed for market data) ===
BINANCE_BASE_URL=https://api.binance.com
BYBIT_BASE_URL=https://api.bybit.com
OKX_BASE_URL=https://www.okx.com

# === CoinGecko ===
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# === DexScreener ===
DEXSCREENER_BASE_URL=https://api.dexscreener.com/latest

# === NOWPayments ===
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_ipn_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_IPN_URL=https://your-domain.up.railway.app/webhooks/nowpayments

# === Pricing (USD) ===
PRICE_PRO_MONTHLY=29.00
PRICE_PRO_YEARLY=249.00
PRICE_ELITE_MONTHLY=99.00
PRICE_ELITE_YEARLY=849.00

# === App ===
LOG_LEVEL=INFO
ENVIRONMENT=production

# === Admin API ===
# Key for the external admin panel API (generate a strong random string)
ADMIN_API_KEY=your-secure-admin-api-key-here

# Dry-run mode: signals are generated & scored but NOT published to channels
# Set to true for initial testing, false for production
DRY_RUN=true
